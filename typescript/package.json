{
  "name": "crdt-sync",
  "version": "0.1.0",
  "description": "TypeScript proxy wrapper for the crdt-sync Wasm StateStore",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run build:wasm:bundler && mkdir -p dist && cp pkg/bundler/*.wasm dist/ && tsc",
    "build:wasm:bundler": "wasm-pack build .. --target bundler --out-dir pkg/bundler",
    "build:wasm:web": "wasm-pack build .. --target web --out-dir pkg/web",
    "build:wasm": "npm run build:wasm:bundler && npm run build:wasm:web",
    "test": "jest",
    "lint": "tsc --noEmit"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
